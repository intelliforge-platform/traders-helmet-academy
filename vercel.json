json
{
  "version": 2,
  "name": "traders-helmet-academy",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/subscription",
      "dest": "/subscription.html"
    },
    {
      "src": "/payment-processing",
      "dest": "/payment-processing.html"
    },
    {
      "src": "/pages/:path*",
      "dest": "/pages/:path*.html"
    },
    {
      "src": "/.*",
      "dest": "/index.html",
      "status": 404
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
