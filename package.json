{
  "name": "traders-helmet-academy",
  "version": "1.0.0",
  "description": "Professional trading education platform with multi-tier subscriptions, video courses, real-time signals, and comprehensive user management.",
  "main": "api/server.js",
  "private": true,
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node api/server.js",
    "dev": "nodemon api/server.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "postcss assets/css/main.css -o dist/css/main.min.css",
    "build:js": "webpack --mode production",
    "watch": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx",
    "lint:fix": "eslint . --ext .js,.jsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,json,css,html}\"",
    "admin:create": "node admin/scripts/create-admin.js",
    "admin:sync": "node admin/scripts/sync-users.js",
    "db:setup": "node admin/scripts/setup-database.js",
    "db:migrate": "node database/migrations/run-migrations.js",
    "db:seed": "node database/seeds/seed-data.js",
    "security:scan": "npm audit",
    "security:fix": "npm audit fix",
    "deploy": "npm run build && npm run test && node scripts/deploy.js",
    "backup": "node scripts/backup-database.js",
    "logs": "pm2 logs",
    "restart": "pm2 restart all",
    "stop": "pm2 stop all"
  },
  "keywords": [
    "trading-education",
    "forex-academy",
    "cryptocurrency-education",
    "binary-options",
    "trading-signals",
    "financial-education",
    "subscription-platform",
    "video-streaming",
    "payment-processing",
    "user-management"
  ],
  "author": {
    "name": "Traders Helmet Academy",
    "email": "support@tradershelmetacademy.com",
    "url": "https://tradershelmetacademy.com"
  },
  "license": "UNLICENSED",
  "homepage": "https://tradershelmetacademy.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tradershelmet/traders-helmet-academy.git"
  },
  "bugs": {
    "url": "https://github.com/tradershelmet/traders-helmet-academy/issues",
    "email": "support@tradershelmetacademy.com"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "ffmpeg-static": "^5.2.0",
    "firebase": "^10.5.0",
    "firebase-admin": "^11.11.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.7",
    "pdf-lib": "^1.17.1",
    "pm2": "^5.3.0",
    "qrcode": "^1.5.3",
    "redis": "^4.6.10",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.4",
    "stripe": "^13.10.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "@types/node": "^20.8.9",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "cssnano": "^6.0.1",
    "eslint": "^8.52.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.2",
    "mini-css-extract-plugin": "^2.7.6",
    "nodemon": "^3.0.1",
    "postcss": "^8.4.31",
    "postcss-cli": "^10.1.0",
    "prettier": "^3.0.3",
    "supertest": "^6.3.3",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!dist/**"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "funding": {
    "type": "subscription",
    "url": "https://tradershelmetacademy.com/subscription"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ]
}